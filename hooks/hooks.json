{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${CLAUDE_PROJECT_DIR:-.}/.remember/logs\" && bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start-hook.sh\" >> \"${CLAUDE_PROJECT_DIR:-.}/.remember/logs/hook-errors.log\" 2>&1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${CLAUDE_PROJECT_DIR:-.}/.remember/logs\" && bash \"${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-hook.sh\" >> \"${CLAUDE_PROJECT_DIR:-.}/.remember/logs/hook-errors.log\" 2>&1"
          }
        ]
      }
    ]
  }
}
